# =============================================================================
# AlertBot Environment Configuration
# =============================================================================
# NOTE: Bot scheduling is controlled by configs/schedule.yaml, not environment variables.
# =============================================================================

# Telegram (required when ALERTBOT_TRANSPORT=telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Private/local-only bot variables should go in `.env.private` (auto-loaded after `.env`)

# Matrix (required when ALERTBOT_TRANSPORT=matrix)
# Example homeserver: https://matrix-client.matrix.org
MATRIX_HOMESERVER_URL=
MATRIX_ACCESS_TOKEN=
# Example room ID: !abc123:matrix.org
MATRIX_ROOM_ID=

# -----------------------------------------------------------------------------
# Stock Bot
# -----------------------------------------------------------------------------
# Provider options: finnhub (default), twelvedata
STOCK_PRICE_PROVIDER=finnhub
# Preferred when STOCK_PRICE_PROVIDER=finnhub
FINNHUB_API_KEY=
# Required when STOCK_PRICE_PROVIDER=twelvedata
# (also accepted as a fallback key for finnhub)
STOCK_PRICE_API_KEY=
# Required for stockbot (comma-separated)
STOCK_TICKERS=AAPL,MSFT,GOOGL
STOCK_CURRENCY=USD

# -----------------------------------------------------------------------------
# Stock Alert Bot
# -----------------------------------------------------------------------------
STOCKALERT_CONFIG=./configs/stockalert.config
STOCKALERT_STATE=./state/stockalert.state.json

# -----------------------------------------------------------------------------
# AQI Bot
# -----------------------------------------------------------------------------
AQI_API_TOKEN=
AQI_PROVIDER=waqi
# Note: AQI_CITY is now controlled via /location command or state/location_state.json
AQI_STATIONS=
AQI_THRESHOLD=80
AQI_MAX_AGE_HOURS=3
AQI_STATE_FILE=./state/airqualitybot_state.json

# -----------------------------------------------------------------------------
# YouTube Bot
# -----------------------------------------------------------------------------
YT_CHANNEL_IDS=
YT_STATE_FILE=./state/ytbot_state.json
# Optional: path to yt-dlp binary (default: yt-dlp from PATH). Used as primary
# fetch method; falls back to YouTube RSS if yt-dlp is unavailable or fails.
YT_YTDLP_BIN=yt-dlp

# -----------------------------------------------------------------------------
# RSS Bot
# -----------------------------------------------------------------------------
# Required: comma-separated feed URLs (single URL also supported)
RSS_FEED_URL=
RSS_STATE_FILE=./state/rssstate.json
RSS_MAX_ITEMS=20

# -----------------------------------------------------------------------------
# Geopolitical Shock Bot (multi-source + infrastructure + market corroboration)
# -----------------------------------------------------------------------------
GEOSHOCK_STATE_FILE=./state/geoshockbot.state.json
GEOSHOCK_NEWS_LOOKBACK_MINUTES=120
GEOSHOCK_MAX_ITEMS=25
GEOSHOCK_MIN_CONFIRMATIONS=4
GEOSHOCK_MIN_HIGH_TRUST=2
GEOSHOCK_PERSISTENCE_RUNS=2
GEOSHOCK_COOLDOWN_MINUTES=480
GEOSHOCK_INFRA_DROP_THRESHOLD_PCT=8
GEOSHOCK_MARKET_JUMP_THRESHOLD_PCT=15
GEOSHOCK_VIX_LEVEL_THRESHOLD=32
GEOSHOCK_OVX_LEVEL_THRESHOLD=50

# -----------------------------------------------------------------------------
# GitHub Bot
# -----------------------------------------------------------------------------
# Personal access token (classic): https://github.com/settings/tokens
# Required scope: notifications (add repo if you need private-repo notification details)
GH_TOKEN=
GH_ALERT_STATE=./state/ghbot.state.json

# -----------------------------------------------------------------------------
# Crypto Bot
# -----------------------------------------------------------------------------
CRYPTOBOT_CONFIG=./configs/cryptobot.config
CRYPTOBOT_STATE=./state/cryptobot.state.json

# -----------------------------------------------------------------------------
# Transaction Bot (Etherscan v2 + Blockscout fallback)
# -----------------------------------------------------------------------------
ETHERSCAN_API_KEY=
# Copy `configs/txbot.config.example.json` to a local path (recommended: configs/private/)
TXBOT_CONFIG=./configs/private/txbot.config.json
TXBOT_STATE=./state/txbot.state.json
TXBOT_API_URL=https://api.etherscan.io/v2/api

# -----------------------------------------------------------------------------
# New Subdomain Bot (subfinder + DNS verification)
# Requires `subfinder` CLI installed: https://github.com/projectdiscovery/subfinder
# `NEWSUBDOMAINBOT_DOMAIN` supports a comma-separated list (e.g. example.com,example.org)
# -----------------------------------------------------------------------------
NEWSUBDOMAINBOT_DOMAIN=
NEWSUBDOMAINBOT_STATE_FILE=./state/newsubdomainbot.state.json
NEWSUBDOMAINBOT_SUBFINDER_BIN=subfinder
NEWSUBDOMAINBOT_SUBFINDER_TIMEOUT_SECONDS=60
NEWSUBDOMAINBOT_ALERT_ON_FIRST_RUN=false

# -----------------------------------------------------------------------------
# Rain Bot (uses Open-Meteo API, no key required)
# Note: Location is controlled via /location command or state/location_state.json
# -----------------------------------------------------------------------------
RAIN_THRESHOLD=45
RAIN_SLEEP_START=02:00
RAIN_SLEEP_END=08:00

# -----------------------------------------------------------------------------
# Calendar Bot
# -----------------------------------------------------------------------------
CALENDARBOT_STATE=./state/calendarbot.state.json

# -----------------------------------------------------------------------------
# Metals Bot
# -----------------------------------------------------------------------------
# Optional (for provider=metalapi): https://metalapi.com
METALAPI_KEY=
# Optional (for provider=metals-api): https://metals-api.com
# METALS_API_KEY=
METALS_CURRENCY=USD
# Provider options: gold-api (default, no key), metalapi, metals-api
METALS_API_PROVIDER=gold-api

# -----------------------------------------------------------------------------
# Aurora Bot (NOAA Kp API, no key required)
# -----------------------------------------------------------------------------
AURORA_SIMPLE_KP_THRESHOLD=7
AURORA_ALERT_COOLDOWN_MINUTES=360
AURORA_STATE_FILE=./state/aurorabot.state.json

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
# Alert transport backend: telegram | matrix
ALERTBOT_TRANSPORT=telegram
# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Optional XDG path overrides for installed-package mode
XDG_CONFIG_HOME=
XDG_STATE_HOME=
# Example values:
# XDG_CONFIG_HOME=~/.config
# XDG_STATE_HOME=~/.local/state
